{
  "name": "@vanillaes/interpolate",
  "version": "3.0.2",
  "description": "Interpret JavaScript tagged literal templates",
  "keywords": [
    "esm",
    "esmodules",
    "javascript",
    "template-engine"
  ],
  "license": "MIT",
  "author": "Evan Plaice <evanplaice@gmail.com> (http://evanplaice.com/)",
  "repository": "http://github.com/vanillaes/interpolate",
  "type": "module",
  "exports": {
    "import": "./index.js",
    "types": "./index.d.ts",
    "browser": "./index.min.js"
  },
  "scripts": {
    "test": "esmtk test",
    "lint": "esmtk lint",
    "type": "esmtk type index.js",
    "build": "npm run build:min && npm run build:typings",
    "build:min": "esmtk minify index.js index.min.js",
    "build:typings": "esmtk typings index.js",
    "clean": "npm run clean:min && npm run clean:typings",
    "clean:min": "esmtk clean --minify",
    "clean:typings": "esmtk clean --typings",
    "preview": "esmtk preview",
    "preversion": "npm test && npm run lint && npm run type",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@vanillaes/esmtk": "^1.2.3"
  }
}
